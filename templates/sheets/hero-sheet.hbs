<div class="litm-hero-sheet">

  <!-- HEADER -->
  <div class="hdr">
    <div class="portrait" data-action="editImage" title="Change portrait">
      {{#if actor.img}}
        <img src="{{actor.img}}" alt="{{actor.name}}">
      {{else}}
        <svg viewBox="0 0 40 40"><circle cx="20" cy="14" r="7" fill="rgba(42,30,16,0.22)"/><path d="M6 38c0-7.7 6.3-14 14-14s14 6.3 14 14" fill="rgba(42,30,16,0.18)"/></svg>
      {{/if}}
    </div>
    <div class="hdr-fields">
      <input class="char-name" type="text" name="name" value="{{actor.name}}" placeholder="Hero's Name…">
      <div class="hdr-meta">
        <input class="mi" type="text" name="system.trope" value="{{system.trope}}" placeholder="Trope…">
      </div>
    </div>
    <div class="wordmark">Legend <em>in the</em> Mist<br><span style="font-size:8px;letter-spacing:2px;">HERO SHEET</span></div>
  </div>

  <!-- ROLL BAR -->
  <div class="rollbar">
    <button type="button" class="roll-btn" data-action="roll" data-roll-type="quick">🎲 Quick Roll</button>
    <button type="button" class="roll-btn" data-action="roll" data-roll-type="detailed">🎲 Detailed Roll</button>
    <button type="button" class="roll-btn" data-action="roll" data-roll-type="reaction">🎲 Reaction Roll</button>
    <span class="rsep"></span>
  </div>

  <!-- ROLL PANEL SLOT -->
  <div id="roll-panel-slot"></div>

  <!-- BODY -->
  <div class="body">

    <!-- LEFT: HERO CARD -->
    <div class="char-panel">
      <div class="cpanel-hdr"><div class="cpanel-hdr-txt">Hero Card</div></div>
      <div class="cpanel-body">

        <div class="sec-title">Fellowship Relationships</div>
        <div class="rel-list">
          {{#each system.relationshipTags}}
          <div class="rel-item">
            <div class="rel-fields">
              <input class="rel-companion" type="text" name="system.relationshipTags.{{@index}}.companionName" value="{{companionName}}" placeholder="Companion…">
              <input class="rel-tag" type="text" name="system.relationshipTags.{{@index}}.tag" value="{{tag}}" placeholder="Relationship tag…">
            </div>
            <button type="button" class="btn-remove" data-action="removeRelationship" data-id="{{id}}">✕</button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="ts-add" data-action="addRelationship">+ relationship</button>

        <div class="track-row">
          <span class="trk-label">Promise</span>
          <div class="trk-dots">
            {{#each promiseDots}}
            <div class="tdot {{#if filled}}on{{/if}}" data-action="setPromise" data-value="{{value}}"></div>
            {{/each}}
          </div>
        </div>

        <div class="sec-title">Quintessences</div>
        <div class="quint-list">
          {{#each system.quintessences}}
          <div class="quint-item">
            <input type="text" name="system.quintessences.{{@index}}.name" value="{{name}}" placeholder="Name…">
            <textarea name="system.quintessences.{{@index}}.effect" placeholder="Effect…" rows="1">{{effect}}</textarea>
            <button type="button" class="btn-remove" data-action="removeQuintessence" data-id="{{id}}">✕</button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="quint-add" data-action="addQuintessence">+ Add Quintessence</button>

      </div>
    </div>

    <!-- CENTER: THEMES -->
    <div class="themes-col">
      {{#each themes}}
      <div class="theme-card">
        <div class="theme-name-row">
          <input class="theme-name-input" type="text" name="system.themes.{{themeIndex}}.name" value="{{name}}" placeholder="Theme name…">
          <div class="might-sel">
            <div class="ms-icon origin {{#if (eq might 'origin')}}on{{/if}}"
                 data-action="setMight" data-theme-id="{{id}}" data-might="origin" title="Origin">🌿</div>
            <div class="ms-icon adventure {{#if (eq might 'adventure')}}on{{/if}}"
                 data-action="setMight" data-theme-id="{{id}}" data-might="adventure" title="Adventure">⚔️</div>
            <div class="ms-icon greatness {{#if (eq might 'greatness')}}on{{/if}}"
                 data-action="setMight" data-theme-id="{{id}}" data-might="greatness" title="Greatness">👑</div>
          </div>
        </div>

        <div class="tags-group">
          <div class="tg-label">Power Tags</div>
          <div class="tags-wrap">
            {{#each powerTags}}
            <span class="tag power {{#if scratched}}scratched{{/if}}"
                  data-action="scratchTag"
                  data-theme-id="{{../id}}"
                  data-tag-id="{{id}}"
                  data-collection="powerTags">{{name}}</span>
            {{/each}}
            <span class="tag add" data-action="addTag" data-theme-id="{{id}}" data-collection="powerTags">+ power tag</span>
          </div>
        </div>

        <div class="tags-group">
          <div class="tg-label">Weakness Tags</div>
          <div class="tags-wrap">
            {{#each weaknessTags}}
            <span class="tag weakness {{#if scratched}}scratched{{/if}}"
                  data-action="scratchTag"
                  data-theme-id="{{../id}}"
                  data-tag-id="{{id}}"
                  data-collection="weaknessTags">{{name}}</span>
            {{/each}}
            <span class="tag add" data-action="addTag" data-theme-id="{{id}}" data-collection="weaknessTags">+ weakness</span>
          </div>
        </div>

        <div class="quest-block">
          <div class="quest-lbl">Quest</div>
          <input class="quest-input" type="text" name="system.themes.{{themeIndex}}.quest" value="{{quest}}" placeholder="What drives this theme?">
        </div>

        <div class="tg-label" style="margin-bottom:5px;">Special Improvements</div>
        <div class="si-list">
          {{#each specialImprovements}}
          <div class="si-item">
            <div class="si-fields">
              <input class="si-name" type="text" name="system.themes.{{../themeIndex}}.specialImprovements.{{@index}}.name" value="{{name}}" placeholder="Name…">
              <input class="si-desc" type="text" name="system.themes.{{../themeIndex}}.specialImprovements.{{@index}}.description" value="{{description}}" placeholder="Effect…">
            </div>
            <button type="button" class="btn-remove" data-action="removeSpecialImprovement" data-theme-id="{{../id}}" data-id="{{id}}">✕</button>
          </div>
          {{/each}}
        </div>
        <button type="button" class="si-add" data-action="addSpecialImprovement" data-theme-id="{{id}}">+ Add Special Improvement</button>

        <div class="aim-track">
          <div class="aim-grp">
            <span class="aim-lbl">Abandon</span>
            <div class="aim-dots">
              {{#each abandonDots}}
              <div class="adot abandon {{#if filled}}on{{/if}}"
                   data-action="setTrack" data-theme-id="{{../id}}" data-track="abandonCount" data-value="{{value}}"></div>
              {{/each}}
            </div>
          </div>
          <div class="aim-grp">
            <span class="aim-lbl">Improve</span>
            <div class="aim-dots">
              {{#each improveDots}}
              <div class="adot {{#if filled}}on{{/if}}"
                   data-action="setTrack" data-theme-id="{{../id}}" data-track="improveCount" data-value="{{value}}"></div>
              {{/each}}
            </div>
          </div>
          <div class="aim-grp">
            <span class="aim-lbl">Milestone</span>
            <div class="aim-dots">
              {{#each milestoneDots}}
              <div class="adot milestone {{#if filled}}on{{/if}}"
                   data-action="setTrack" data-theme-id="{{../id}}" data-track="milestoneCount" data-value="{{value}}"></div>
              {{/each}}
            </div>
          </div>
        </div>

      </div>
      {{/each}}
    </div>

    <!-- RIGHT COLUMN -->
    <div class="right-col">

      <div class="rcol-sec">
        <div class="rsec-title">Statuses</div>
        {{#each statuses}}
        <div class="status-row">
          <div class="status-pill">
            <input class="sname" type="text" data-status-index="{{@index}}" value="{{name}}" placeholder="Status…">
            <span class="tier-boxes">
              {{#each boxes}}
              <span class="stb {{#if isActive}}active{{else}}{{#if marked}}on{{/if}}{{/if}}"
                    data-action="toggleStatusBox"
                    data-status-id="{{../id}}"
                    data-tier="{{tier}}">{{tier}}</span>
              {{/each}}
            </span>
          </div>
        </div>
        {{/each}}
        <button type="button" class="status-add" data-action="addStatus">+ Add Status</button>

        <div class="rsec-title" style="margin-top:12px;">Backpack</div>
        {{#each system.backpack}}
        <div class="bp-item">
          <span class="bp-scratch {{#if scratched}}on{{/if}}"
                data-action="scratchBackpackItem" data-id="{{id}}" title="Scratch">///</span>
          <input class="bp-inp {{#if scratched}}scratched{{/if}}" type="text"
                 name="system.backpack.{{@index}}.name" value="{{name}}" placeholder="Item or story tag…">
          <button type="button" class="btn-remove" data-action="removeBackpackItem" data-id="{{id}}">✕</button>
        </div>
        {{/each}}
        <button type="button" class="bp-add" data-action="addBackpackItem">+ Add tag</button>
      </div>

      <div class="rcol-sec">
        <div class="rsec-title">Fellowship Tags</div>
        <div class="fi-tags">
          {{#if fellowship}}
            {{#if fellowship.titleTag.name}}
            <span class="tag power {{#if fellowship.titleTag.scratched}}scratched{{/if}}"
                  data-action="scratchFellowshipTag"
                  data-tag-type="titleTag"
                  data-tag-id="{{fellowship.titleTag.id}}">{{fellowship.titleTag.name}}</span>
            {{/if}}
            {{#each fellowship.powerTags}}
            <span class="tag power {{#if scratched}}scratched{{/if}}"
                  data-action="scratchFellowshipTag"
                  data-tag-type="powerTag"
                  data-tag-id="{{id}}">{{name}}</span>
            {{/each}}
            {{#each fellowship.weaknessTags}}
            <span class="tag weakness {{#if scratched}}scratched{{/if}}"
                  data-action="scratchFellowshipTag"
                  data-tag-type="weaknessTag"
                  data-tag-id="{{id}}">{{name}}</span>
            {{/each}}
          {{else}}
            <span class="hint">No Fellowship linked — set one in system settings.</span>
          {{/if}}
        </div>
      </div>

    </div>

  </div>
</div>
